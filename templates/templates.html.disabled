<!-- WRITING PART TEMPLATE -->

<!-- ── Part 1 ────────────────────────────────────── -->
<details class="hub-part">
    <summary style="list-style:none; cursor:pointer;">
    <span class="hub-part-label">Part 1</span>
    <h2 class="hub-part-title">Part Title</h2>
    </summary>

    <ul class="hub-chapter-list">

    <!--
        One <li> per chapter.
        href  — relative path to the chapter file
        data-words — word count for this chapter
    -->
    <li class="hub-chapter-item" data-words="0">
        <a href="p1-ch1.html" class="hub-chapter-link">
        <span class="hub-chapter-num">Ch. 1</span>
        <span class="hub-chapter-title">Chapter Title</span>
        <span class="hub-chapter-words" data-chapter-time></span>
        </a>
    </li>

    <li class="hub-chapter-item" data-words="0">
        <a href="p1-ch2.html" class="hub-chapter-link">
        <span class="hub-chapter-num">Ch. 2</span>
        <span class="hub-chapter-title">Chapter Title</span>
        <span class="hub-chapter-words" data-chapter-time></span>
        </a>
    </li>

    <li class="hub-chapter-item" data-words="0">
        <a href="p1-ch3.html" class="hub-chapter-link">
        <span class="hub-chapter-num">Ch. 3</span>
        <span class="hub-chapter-title">Chapter Title</span>
        <span class="hub-chapter-words" data-chapter-time></span>
        </a>
    </li>

    <!-- Add more chapters by duplicating the <li> above -->

    </ul>
</details>

<!-- WRITING PAGE TAB TEMPLATES -->

<!-- ── TEMPLATE: Multi-Part Fiction ───────────────── -->
<!--
    href points to the story's hub/index page.
    data-words is the TOTAL word count across all chapters.
    Update "Series · Part 1 of ?" when you know the final count.
-->
<a href="/writing/your-story/index.html" class="card writing-card" data-words="0">
    <div class="writing-card-meta">
    <span class="writing-tag">Dark Fantasy</span>
    <span class="writing-tag writing-tag--type">Novel</span>
    <span class="writing-meta-sep"></span>
    <span class="writing-read-time" data-read-time></span>
    <span class="writing-meta-sep"></span>
    <span class="writing-series-badge">Ongoing · Part 1 of ?</span>
    </div>
    <h3 class="writing-card-title">Your Story Title</h3>
    <p class="writing-card-excerpt">
    A 2–3 sentence excerpt or premise summary that gives the reader a feel
    for the world, tone, and stakes — without giving away the plot.
    </p>
</a>


<!-- ── TEMPLATE: Short Fiction ────────────────────── -->
<!--
    href points directly to the story page.
    data-words is the word count of this single piece.
    Remove the .writing-series-badge if it's a standalone.
-->
<a href="/writing/your-short-story.html" class="card writing-card" data-words="0">
    <div class="writing-card-meta">
    <span class="writing-tag">Sci-Fi</span>
    <span class="writing-tag writing-tag--type">Short Story</span>
    <span class="writing-meta-sep"></span>
    <span class="writing-read-time" data-read-time></span>
    </div>
    <h3 class="writing-card-title">Your Story Title</h3>
    <p class="writing-card-excerpt">
    A 2–3 sentence excerpt or premise summary. Short stories benefit from
    leading with a hook or central image rather than a synopsis.
    </p>
</a>


<!-- ── TEMPLATE: Blog Post / Essay ───────────────── -->
